{
  "permissions": {
    "allow": [
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "Skill(implement-issue)",
      "Skill(implement-issue:*)",
      "Skill(git-worktree)",
      "Skill(git-worktree:*)",
      "Skill(init-setup-worktree)",
      "Skill(init-setup-worktree:*)",
      "Skill(setup-worktree)",
      "Skill(setup-worktree:*)",
      "SandboxNetworkAccess(registry.npmjs.org:443)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod 777 *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.env.*.local)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [],
    "additionalDirectories": [
      "/Users/kenta/.claude/skills"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'あなたの入力が必要です' -sound default"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'タスクが完了しました' -sound default"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk-hook-custom"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh",
        "**/.env",
        "**/.env.*"
      ],
      "allowRead": [
        "**/.env.example"
      ]
    }
  },
  "effortLevel": "max",
  "tui": "fullscreen",
  "theme": "dark-daltonized",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
